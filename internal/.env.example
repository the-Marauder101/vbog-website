# Reddit API Credentials (free at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=VBOG-Monitor/1.0

# Listening Configuration
# Comma-separated subreddits to monitor
SUBREDDITS=entrepreneur,startups,smallbusiness,SaaS,business,Bookkeeping,Accounting,tax,IndianStockMarket,IndiaBusiness
# Comma-separated keywords (case-insensitive)
KEYWORDS=bookkeeping,accounting,virtual cfo,cfo services,financial reporting,tax filing,gst,payroll,accounts payable,accounts receivable,outsource accounting,offshore accounting,back office,business operations,vbog,v-bog
# Comma-separated high-intent phrases
HIGH_INTENT_PHRASES=looking for,need help with,recommend,suggestion,anyone use,best service,how to find,where can i,searching for,can someone suggest,affordable,cost of,pricing,hire,outsource
# Minimum keyword matches to flag a post (1-5)
MIN_KEYWORD_MATCHES=1
# Also require at least one high-intent phrase match
REQUIRE_INTENT=true
# How often to poll Reddit (in minutes)
POLL_INTERVAL_MINUTES=10
# Maximum posts to fetch per subreddit per poll
MAX_POSTS_PER_POLL=25

# WhatsApp Notifications via CallMeBot (free, see https://www.callmebot.com/blog/free-api-whatsapp-messages/)
# Step 1: Add +34 644 52 74 88 to your WhatsApp contacts
# Step 2: Send "I allow callmebot to send me messages" to that number
# Step 3: You'll receive an API key - put it below
WHATSAPP_ENABLED=false
WHATSAPP_PHONE=your_phone_with_country_code
WHATSAPP_API_KEY=your_callmebot_api_key
# Comma-separated additional phone numbers for team notifications
WHATSAPP_TEAM_PHONES=
WHATSAPP_TEAM_API_KEYS=

# Server
HOST=0.0.0.0
PORT=8000
