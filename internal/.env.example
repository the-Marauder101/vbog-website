# No Reddit API key needed! The bot uses Reddit's public JSON endpoints.
# Just run ./run.sh and click "Scan Now" in the dashboard.

# User agent for Reddit requests (change to avoid rate limiting)
REDDIT_USER_AGENT=VBOG-Monitor/1.0

# Keywords — the bot searches ALL of Reddit for these (comma-separated)
# You can also edit these from the dashboard Settings panel
KEYWORDS=bookkeeping,accounting,virtual cfo,cfo services,financial reporting,tax filing,gst,payroll,accounts payable,accounts receivable,outsource accounting,offshore accounting,back office,business operations,vbog,v-bog

# High-intent phrases — posts must contain at least one of these to be flagged
HIGH_INTENT_PHRASES=looking for,need help with,recommend,suggestion,anyone use,best service,how to find,where can i,searching for,can someone suggest,affordable,cost of,pricing,hire,outsource

# Minimum keyword matches to flag a post
MIN_KEYWORD_MATCHES=1
# Require at least one high-intent phrase (set to false for more results)
REQUIRE_INTENT=true
# How often to auto-scan (minutes)
POLL_INTERVAL_MINUTES=10
# Max posts to check per keyword per scan
MAX_POSTS_PER_POLL=25

# WhatsApp Notifications via CallMeBot (free)
# Setup: 1) Add +34 644 52 74 88 to WhatsApp contacts
#         2) Send "I allow callmebot to send me messages" to that number
#         3) You'll get an API key — put it below
WHATSAPP_ENABLED=false
WHATSAPP_PHONE=your_phone_with_country_code
WHATSAPP_API_KEY=your_callmebot_api_key
# Additional team members (comma-separated, must each set up CallMeBot)
WHATSAPP_TEAM_PHONES=
WHATSAPP_TEAM_API_KEYS=

# Server
HOST=0.0.0.0
PORT=8000
